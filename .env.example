# Database connection string
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gastown_fin

# OpenRouter API key for LLM routing
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Massive (Polygon.io) API key for market data
# When set and non-empty, uses real market data instead of the simulator
MASSIVE_API_KEY=

# Poll interval in seconds for the Massive API (default: 15)
# Free tier: 15s minimum; paid tier: 2-15s
MASSIVE_POLL_INTERVAL=15

# Set to true to use mock LLM responses (no API keys needed)
LLM_MOCK=true
